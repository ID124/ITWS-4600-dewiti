## Metrics
# kNN metrics
grade_levels <- levels(final_dataset$grade)
# Fix kNN predictions
knn.predicted <- factor(knn.predicted, levels = grade_levels)
edu.test$grade <- factor(edu.test$grade, levels = grade_levels)
# Fix Random Forest predictions
rf.predicted <- factor(rf.predicted, levels = grade_levels)
# Confusion matrix
knn_cm <- confusionMatrix(
data = knn.predicted,
reference = edu.test$grade
)
knn_matrix <- as.matrix(table(Actual = final_dataset$grade, Predicted = knn.predicted))
knn_matrix <- as.matrix(table(Actual = edu.test$grade, Predicted = knn.predicted))
n = sum(knn_matrix)
nc = nrow(knn_matrix)
diagv = diag(knn_matrix)
rowsums = apply(knn_matrix, 1, sum)
colsums = apply(knn_matrix, 2, sum)
p = rowsums / n
q = colsums / n
accuracy <- sum(diagv)/n
accuracy
recall = diagv / rowsums
recall
precision = diagv / colsums
precision
f1 = 2 * precision * recall / (precision + recall)
f1
# kNN metrics
confusionMatrix(
data = factor(knn.predicted, levels = levels(final_dataset$grade)),
reference = factor(edu.test$grade, levels = levels(final_dataset$grade))
)
